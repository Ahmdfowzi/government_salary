# Production environment for the Iraqi Government Payroll stack.
# ---------------------------------------------------------------------------
# Copy to `.env.production` (which is git-ignored) and fill in REAL values.
# This example file MUST NOT contain real secrets — only placeholders.
# Generate strong secrets, e.g.:  openssl rand -base64 32
#
# go-live-check.sh refuses go-live while any value below is still a default.
# ---------------------------------------------------------------------------

# --- Site ---
FRAPPE_SITE=payroll.example.gov.iq          # your real production hostname
PUBLIC_HOST=payroll.example.gov.iq          # hostname nginx terminates TLS for

# --- Database (MariaDB root + site DB) ---
# Do NOT use the dev value "123".
MYSQL_ROOT_PASSWORD=__CHANGE_ME__strong_db_root_password__

# --- Frappe Administrator account ---
# Do NOT use the dev value "admin".
ADMIN_PASSWORD=__CHANGE_ME__strong_admin_password__

# --- Frappe secrets (generate unique random values) ---
ENCRYPTION_KEY=__CHANGE_ME__openssl_rand_base64_32__

# --- Gunicorn / workers ---
GUNICORN_WORKERS=4                          # ~= (2 * vCPU) + 1
GUNICORN_TIMEOUT=300                        # seconds; payroll requests are short (runs are async)

# --- Frontend (Next.js) ---
# The frontend proxies /api to Frappe via this target (server-side only).
FRAPPE_PROXY_TARGET=http://frappe:8000

# --- TLS (certbot) ---
CERTBOT_EMAIL=ops@example.gov.iq

# --- Monitoring (optional but recommended) ---
# SENTRY_DSN=
# Set these to wire failed-run / backup-failure alerts (see production/README.md).
# ALERT_WEBHOOK_URL=
