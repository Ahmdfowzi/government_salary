# --- API transport -----------------------------------------------------------
# By default the frontend calls its OWN origin (relative /api/...) and the Next
# server proxies those requests to Frappe (see next.config.mjs). This avoids
# CORS and host-routing ("Load failed") issues, so you normally leave
# NEXT_PUBLIC_FRAPPE_BASE_URL EMPTY/unset.
#
# Set it to an absolute URL only when the frontend is served on the SAME origin
# as Frappe, or Frappe CORS is configured for this origin.
# NEXT_PUBLIC_FRAPPE_BASE_URL=

# Where the Next proxy forwards /api, /files, /private/files. Must be the Frappe
# SITE host (host-based routing) — `http://localhost:8000` would 404 the site.
FRAPPE_PROXY_TARGET=http://payroll.localhost:8000
